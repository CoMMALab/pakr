<mujoco>
  <option gravity="0 0 -9.81" />
  <compiler autolimits="true" angle="degree" coordinate="local"/>
  <actuator>
    <velocity name="ee_x" joint="ee_x" gear="1" kv="10" forcerange="-100 100"/>
    <velocity name="ee_y" joint="ee_y" gear="1" kv="10" forcerange="-100 100"/>
  </actuator>
  <worldbody>
    <body name="table" pos="0 0 0">
      <geom type="plane" size="1 1 0.1" rgba="0.5 0.5 0.5 1" contype="1" conaffinity="1"/>
    </body>

    <!-- End-effector -->
    <body name="ee" pos="0.2 0 0.05">
      <geom type="sphere" size="0.03" rgba="0 0 1 1"/>
      <joint name="ee_x" type="slide" axis="1 0 0"/>
      <joint name="ee_y" type="slide" axis="0 1 0"/>
    </body>

    <!-- Multiple cubes -->
    <!-- Loop in Python or generate MJCF -->
    <body name="obj0" pos="0.2 0.2 1">
			<inertial mass="0.1" diaginertia="0.00004 0.00004 0.00004" pos="0 0 0"/>
      <geom type="box" size="0.025 0.025 0.025" rgba="1 0 0 1"/>
      <joint type="free"/>
    </body>
    <!-- repeat for obj1, obj2, ... -->
    <body name="obj1" pos="-0.2 0.2 1">
			<inertial mass="0.1" diaginertia="0.00004 0.00004 0.00004" pos="0 0 0"/>
      <geom type="box" size="0.025 0.025 0.025" rgba="1 0 0 1"/>
      <joint type="free"/>
    </body>
    <body name="obj2" pos="0.2 -0.2 1">
			<inertial mass="0.1" diaginertia="0.00004 0.00004 0.00004" pos="0 0 0"/>
      <geom type="box" size="0.025 0.025 0.025" rgba="1 0 0 1"/>
      <joint type="free"/>
    </body>
    <body name="obj3" pos="-0.2 -0.2 1">
			<inertial mass="0.1" diaginertia="0.00004 0.00004 0.00004" pos="0 0 0"/>
      <geom type="box" size="0.025 0.025 0.025" rgba="1 0 0 1"/>
      <joint type="free"/>
    </body>
  </worldbody>
</mujoco>
