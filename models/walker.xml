<mujoco model="walker2d">
  <compiler angle="radian" inertiafromgeom="true"/>
  
  <default>
    <joint armature="0.01" damping="0.1" limited="true"/>
    <geom conaffinity="0" condim="3" contype="1" density="1000" friction="0.7 0.1 0.1"/>
  </default>

  <option timestep="0.005" iterations="4" ls_iterations="4" solver="Newton" jacobian="dense" integrator="Euler">
  </option>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="40 40 0.05" rgba="0.8 0.9 0.8 1"/>

    <body name="torso" pos="0 0 1.25">
      <joint name="rootx" type="slide" axis="1 0 0" limited="false" pos="0 0 0" armature="0" damping="0"/>
      <joint name="rootz" type="slide" axis="0 0 1" limited="false" pos="0 0 0" armature="0" damping="0"/>
      <joint name="rooty" type="hinge" axis="0 1 0" limited="false" pos="0 0 0" armature="0" damping="0"/>
      <geom name="torso_geom" type="capsule" size="0.05 0.2" rgba="0.7 0.7 0.7 1"/>

      <body name="right_thigh" pos="0 0 -0.2">
        <joint name="right_hip" type="hinge" axis="0 1 0" range="-1.0 1.0"/>
        <geom name="right_thigh_geom" type="capsule" size="0.05 0.225" pos="0 0 -0.225" rgba="0.3 0.6 0.3 1"/>
        <body name="right_shin" pos="0 0 -0.45">
          <joint name="right_knee" type="hinge" axis="0 1 0" range="-1.5 0"/>
          <geom name="right_shin_geom" type="capsule" size="0.04 0.25" pos="0 0 -0.25" rgba="0.3 0.6 0.3 1"/>
          <body name="right_foot" pos="0 0 -0.5">
            <joint name="right_ankle" type="hinge" axis="0 1 0" range="-0.75 0.75"/>
            <geom name="right_foot_geom" type="capsule" size="0.05 0.1" pos="0.1 0 0.1" zaxis="1 0 0" rgba="0.3 0.6 0.3 1"/>
          </body>
        </body>
      </body>

      <body name="left_thigh" pos="0 0 -0.2">
        <joint name="left_hip" type="hinge" axis="0 1 0" range="-1.0 1.0"/>
        <geom name="left_thigh_geom" type="capsule" size="0.05 0.225" pos="0 0 -0.225" rgba="0.3 0.3 0.6 1"/>
        <body name="left_shin" pos="0 0 -0.45">
          <joint name="left_knee" type="hinge" axis="0 1 0" range="-1.5 0"/>
          <geom name="left_shin_geom" type="capsule" size="0.04 0.25" pos="0 0 -0.25" rgba="0.3 0.3 0.6 1"/>
          <body name="left_foot" pos="0 0 -0.5">
            <joint name="left_ankle" type="hinge" axis="0 1 0" range="-0.75 0.75"/>
            <geom name="left_foot_geom" type="capsule" size="0.05 0.1" pos="0.1 0 0.1" zaxis="1 0 0" rgba="0.3 0.3 0.6 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="right_hip" joint="right_hip" gear="100" ctrlrange="-1 1"/>
    <motor name="right_knee" joint="right_knee" gear="50" ctrlrange="-1 1"/>
    <motor name="right_ankle" joint="right_ankle" gear="20" ctrlrange="-1 1"/>
    <motor name="left_hip" joint="left_hip" gear="100" ctrlrange="-1 1"/>
    <motor name="left_knee" joint="left_knee" gear="50" ctrlrange="-1 1"/>
    <motor name="left_ankle" joint="left_ankle" gear="20" ctrlrange="-1 1"/>
  </actuator>
</mujoco>