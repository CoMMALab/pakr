<mujoco model="franka_pusher_mjx">
    <compiler angle="radian" coordinate="local" autolimits="true"/>

    <option timestep="0.01" gravity="0 0 -9.81" iterations="20" solver="Newton" jacobian="dense">
        <flag contact="enable"/>
    </option>

    <default>
        <geom contype="1" conaffinity="1" condim="3" friction="1 0.005 0.0001" density="1000"/>
        <joint armature="0.1" damping="1" limited="true"/>
        <general ctrllimited="true" ctrlrange="-150 150"/>
    </default>

    <asset>
        <material name="table_mat" rgba="0.3 0.3 0.3 1"/>
        <material name="block_mat" rgba="0.9 0.2 0.2 1"/>
        <material name="arm_mat" rgba="0.8 0.8 0.8 1"/>
    </asset>

    <worldbody>
        <light pos="0 0 2" dir="0 0 -1"/>

        <geom name="floor" type="plane" size="1 1 0.05" pos="0 0 0" material="table_mat"/>

        <body name="link0" pos="0 0 0.025">
            <geom type="sphere" size="0.05" material="arm_mat"/>
            
            <body name="link1" pos="0 0 0.05">
                <joint name="joint1" axis="0 0 1" range="-2.89 2.89"/>
                <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.03"/>

                <body name="link2" pos="0 0 0.1">
                    <joint name="joint2" axis="0 1 0" range="-1.76 1.76"/>
                    <geom type="capsule" fromto="0 0 0 0 0 0.2" size="0.03"/>
                    
                    <body name="link3" pos="0 0 0.2">
                        <joint name="joint3" axis="0 0 1" range="-2.89 2.89"/>
                        <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.03"/>

                        <body name="link4" pos="0 0 0.1">
                            <joint name="joint4" axis="0 -1 0" range="-3.07 -0.06"/>
                            <geom type="capsule" fromto="0 0 0 0 0 0.2" size="0.03"/>
                            
                            <body name="link5" pos="0 0 0.2">
                                <joint name="joint5" axis="0 0 1" range="-2.89 2.89"/>
                                <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.03"/>

                                <body name="link6" pos="0 0 0.1">
                                    <joint name="joint6" axis="0 1 0" range="-0.01 3.75"/>
                                    <geom type="capsule" fromto="0 0 0 0 0 0.05" size="0.03"/>
                                    
                                    <body name="link7" pos="0 0 0.05">
                                        <joint name="joint7" axis="0 0 1" range="-2.89 2.89"/>
                                        <geom type="capsule" fromto="-0.05 0 0 0.05 0 0" size="0.02" material="arm_mat"/>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>

        <body name="block" pos="0.4 0 0.03">
            <freejoint name="block_free"/>
            <geom type="capsule" size="0.03 0.01" material="block_mat" mass="0.1"/>
        </body>
    </worldbody>

    <actuator>
        <motor joint="joint1" name="m1"/>
        <motor joint="joint2" name="m2"/>
        <motor joint="joint3" name="m3"/>
        <motor joint="joint4" name="m4"/>
        <motor joint="joint5" name="m5"/>
        <motor joint="joint6" name="m6"/>
        <motor joint="joint7" name="m7"/>
    </actuator>
</mujoco>