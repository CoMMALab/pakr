<mujoco model="acrobot">

  <option timestep="0.01" gravity="0 0 -9.81"/>

  <size njmax="50" nconmax="10"/>

  <asset>

    <!-- floor texture -->
    <texture name="grid" type="2d" builtin="checker"
             rgb1=".2 .3 .4" rgb2=".1 .2 .3"
             width="300" height="300"
             mark="cross" markrgb=".8 .8 .8"/>

    <material name="floor_mat"
              texture="grid"
              texrepeat="5 5"
              reflectance=".2"/>

    <!-- acrobot materials -->
    <material name="link1_mat"
              rgba="0.2 0.6 1 1"
              shininess="0.7"
              specular="0.4"/>

    <material name="link2_mat"
              rgba="1 0.4 0.2 1"
              shininess="0.7"
              specular="0.4"/>

    <!-- goal ghost -->
    <material name="goal_mat"
              rgba="0 1 0 0.25"
              shininess="0.1"
              specular="0.1"/>

  </asset>

  <worldbody>

    <!-- lighting -->
    <light directional="true"
           diffuse=".8 .8 .8"
           pos="0 0 5"
           dir="0 0 -1"
           specular="0.3 0.3 0.3"/>

    <!-- floor -->
    <geom type="plane"
          size="5 5 0.1"
          material="floor_mat"/>

    <!-- pivot marker -->
    <geom type="sphere"
          size="0.04"
          pos="0 0 0"
          rgba="0.8 0.8 0.8 1"
          contype="0"
          conaffinity="0"/>

    <!-- ========================= -->
    <!-- ACTUAL ACROBOT -->
    <!-- ========================= -->

    <body name="link1" pos="0 0 0">

      <joint name="q1"
             type="hinge"
             axis="0 0 1"
             damping="0.1"/>

      <geom type="capsule"
            fromto="0 0 0   1 0 0"
            size="0.05"
            material="link1_mat"/>

      <body name="link2" pos="1 0 0">

        <joint name="q2"
               type="hinge"
               axis="0 0 1"
               damping="0.1"/>

        <geom type="capsule"
              fromto="0 0 0   1 0 0"
              size="0.05"
              material="link2_mat"/>

      </body>
    </body>


    <!-- ========================= -->
    <!-- GOAL POSE (visual only) -->
    <!-- ========================= -->
    <!-- goal: q1 = pi, q2 = 0 -->

    <body name="goal_link1"
          pos="0 0 0"
          quat="0 0 0 1">

      <!-- rotate 180 deg around Z -->
      <joint type="hinge" axis="0 0 1" limited="false"/>

      <geom type="capsule"
            fromto="0 0 0  -1 0 0"
            size="0.04"
            material="goal_mat"
            contype="0"
            conaffinity="0"/>

      <body pos="-1 0 0">

        <geom type="capsule"
              fromto="0 0 0  -1 0 0"
              size="0.04"
              material="goal_mat"
              contype="0"
              conaffinity="0"/>

      </body>

    </body>

  </worldbody>

</mujoco>