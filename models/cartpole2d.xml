<mujoco model="Cartpole">
  <compiler angle="radian" inertiafromgeom="true"/>

  <default>
    <joint armature="0" damping="0.1" frictionloss="0" type="hinge"/>
    <geom contype="0" conaffinity="0" density="1000"/>
  </default>

  <option timestep="0.02" integrator="Euler" solver="Newton" iterations="1"/>

  <worldbody>
    <!-- Ground plane -->
    <geom type="plane" size="5 5 0.1" contype="0" conaffinity="0"/>

    <!-- Cart -->
    <body name="cart" pos="0 0 0">
      <joint name="slider" type="slide" axis="1 0 0" range="-4.8 4.8"/>
      <geom type="box" size="0.3 0.15 0.1" mass="1.0"/>

      <!-- Pole -->
      <body name="pole" pos="0 0 0">
        <joint name="hinge" type="hinge" axis="0 1 0"/>
        <geom type="capsule" size="0.02 0.5" pos="0 0 0.5" mass="0.1"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="force_actuator" joint="slider" ctrlrange="-10 10"/>
  </actuator>
</mujoco>